{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://chatapp-be-3nou.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://chatapp-be-3nou.onrender.com/socket.io/:path*"
    }
  ]
}